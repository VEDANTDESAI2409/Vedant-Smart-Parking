# Environment Configuration
NODE_ENV=development

# Server Configuration
PORT=5000
CLIENT_URL=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/smart-parking-system

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here-change-in-production
JWT_EXPIRE=7d

# Development Admin Fallback
ALLOW_SERVER_WITHOUT_DB=false
ALLOW_DEV_ADMIN_LOGIN=true
DEV_ADMIN_EMAIL=admin@smartparking.com
DEV_ADMIN_PASSWORD=admin123

# Email Configuration (for notifications)
EMAIL_FROM=noreply@smartparking.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Payment Gateway Configuration (Stripe example)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# File Upload Configuration
MAX_FILE_SIZE=5000000
FILE_UPLOAD_PATH=./uploads

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# Logging
LOG_LEVEL=info

# Admin Configuration
DEFAULT_ADMIN_EMAIL=admin@smartparking.com
DEFAULT_ADMIN_PASSWORD=Admin123!

# Notification Settings
SMS_ENABLED=false
PUSH_ENABLED=true
EMAIL_ENABLED=true

# Cache Configuration
REDIS_URL=redis://localhost:6379

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
